NODE_ENV=production
PORT=8080

# MongoDB Atlas connection string. Replace username/password/cluster/db name.
MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/ZAc201_living?retryWrites=true&w=majority

# Use a long random string in production.
SESSION_SECRET=replace-with-a-long-random-secret

# Private admin login. Do not expose this publicly.
ADMIN_EMAIL=zacadmin@zac.living
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# WhatsApp number with country code, no + sign.
WHATSAPP_NUMBER=919301942717

# Optional: append newly created admin listings to Google Sheets.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Listings
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
