<% layout('/layouts/boilerplate') -%>

<section class="container room-detail-page prao-detail-layout max-w-7xl px-4 py-5 sm:px-6 lg:px-8">
  <div class="product-gallery" aria-label="Room photos">
    <% room.photos.forEach((photo, index) => { %>
      <div class="product-gallery-tile <%= index === 0 ? 'featured' : '' %>">
        <img src="<%= photo %>" alt="<%= room.title %> photo <%= index + 1 %>">
        <% if (index === 0 && room.videoUrl) { %>
          <a href="<%= room.videoUrl %>" target="_blank" rel="noopener" class="gallery-video-overlay">
            <i class="fa-solid fa-circle-play"></i>
            <span>Watch Video Tour</span>
          </a>
        <% } %>
      </div>
    <% }) %>
  </div>

  <div class="detail-card min-w-0 room-detail-card">
    <div class="room-card-top flex flex-wrap items-center justify-between gap-2">
      <span class="status-badge <%= room.availability.toLowerCase().replaceAll(' ', '-') %>"><%= room.availability %></span>
      <% if (room.videoUrl) { %><a class="video-badge" href="<%= room.videoUrl %>" target="_blank" rel="noopener"><i class="fa-solid fa-play"></i> Video/vlog tour</a><% } %>
    </div>
    <h1 class="break-words"><%= room.title %></h1>
    <p class="detail-rent">Rs. <%= room.rent.toLocaleString("en-IN") %> / month | Deposit Rs. <%= room.deposit.toLocaleString("en-IN") %></p>
    <p class="muted"><i class="fa-solid fa-location-dot"></i> <%= room.area %>, <%= room.landmark %></p>
    <p class="detail-description"><%= room.description %></p>

    <div class="detail-grid grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div><strong>Category</strong><span><%= room.category %></span></div>
      <div><strong>Room type</strong><span><%= room.roomType %></span></div>
      <div><strong>Food</strong><span><%= room.food %> | <%= room.foodDetails %></span></div>
      <div><strong>Utilities</strong><span><%= room.utilities %></span></div>
      <div><strong>Safety</strong><span><%= room.safetyNotes %></span></div>
      <div><strong>Distance</strong><span><%= room.distanceNotes %></span></div>
    </div>

    <section class="detail-section">
      <h2>Facilities</h2>
      <div class="facility-list flex flex-wrap gap-2">
        <% room.facilities.forEach((facility) => { %><span><%= facility %></span><% }) %>
      </div>
    </section>

    <% if (room.nearbyPlaces && room.nearbyPlaces.length) { %>
      <section class="detail-section">
        <h2>Nearby within 1 km</h2>
        <div class="nearby-list">
          <% room.nearbyPlaces.forEach((place) => { %>
            <div><i class="fa-solid fa-location-dot"></i><span><%= place %></span></div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <section class="detail-section">
      <h2>Rules</h2>
      <ul class="rule-list">
        <% room.rules.forEach((rule) => { %><li><%= rule %></li><% }) %>
      </ul>
    </section>

    <div class="detail-actions">
      <% if (room.videoUrl) { %>
        <a href="<%= room.videoUrl %>" target="_blank" rel="noopener" class="btn btn-primary video-action-btn w-full">
          <i class="fa-solid fa-play"></i> Watch Video Tour
        </a>
      <% } %>
      <form method="post" action="/rooms/<%= room.id %>/visit" class="w-full">
        <button class="btn btn-primary w-full" type="submit">Request Visit</button>
      </form>
      <form method="post" action="/rooms/<%= room.id %>/favorite" class="w-full">
        <button class="btn btn-outline-primary w-full" type="submit"><%= room.isFavorite ? "Saved" : "Save Room" %></button>
      </form>
      <% if (currentUser && currentUser.role === "student") { %>
        <a href="/support/whatsapp" class="btn btn-outline-primary w-full">WhatsApp Support</a>
      <% } else { %>
        <a href="/login" class="btn btn-outline-primary w-full">Login for WhatsApp Support</a>
      <% } %>
    </div>
  </div>
</section>
